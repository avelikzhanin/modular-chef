# Локально: postgresql+asyncpg://chef:chef@localhost:5432/modular_chef
# Railway: будет проставлен автоматически при добавлении Postgres плагина
DATABASE_URL=postgresql+asyncpg://chef:chef@localhost:5432/modular_chef

# Ключ от Anthropic для генерации меню (Stage 5)
# Получить: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Опционально: модель Claude. По умолчанию claude-sonnet-4-6 (быстрее) или
# можно claude-opus-4-7 для повышенного качества генерации.
CLAUDE_MODEL=claude-sonnet-4-6

# Лог-уровень (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO
