# Локально: postgresql+asyncpg://chef:chef@localhost:5432/modular_chef
# Railway: будет проставлен автоматически при добавлении Postgres плагина
DATABASE_URL=postgresql+asyncpg://chef:chef@localhost:5432/modular_chef

# Ключ OpenAI для генерации меню (Stage 5)
# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Опционально: модель. По умолчанию gpt-4o-mini (дёшево, $0.15/$0.60 за 1M),
# для премиум качества — gpt-4o.
OPENAI_MODEL=gpt-4o-mini

# Лог-уровень (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO
